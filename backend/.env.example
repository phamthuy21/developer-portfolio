# Database (Local Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5433/portfolio?schema=public"

# Database (Supabase Production example)
# DATABASE_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Application
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,https://portfolio-production.vercel.app

# Authentication (Phase 4 Placeholders)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
