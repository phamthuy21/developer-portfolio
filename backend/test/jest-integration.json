{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "testPathIgnorePatterns": ["/node_modules/", "/src/", "/test/e2e/"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/test/jest-setup.ts"],
  "testTimeout": 30000,
  "maxWorkers": 1
}
